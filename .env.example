# ── Chutes LLM ──────────────────────────────────────────────────────────────
Chutes_api_key=your_chuetes_api_key
CHUTES_MODEL=moonshotai/Kimi-K2.6-TEE

# ── GitHub OAuth ────────────────────────────────────────────────────────────
# Register TWO GitHub OAuth apps (https://github.com/settings/developers):
#   • Production app → callback URL = https://<your-app>.onrender.com/api/auth/github/callback
#   • Local app      → callback URL = http://localhost:3000/api/auth/github/callback
# The server picks the right pair automatically (production on Render, local
# otherwise). Force it explicitly with GITHUB_ENV=local|production if needed.

# Production credentials (used on Render / when NODE_ENV=production)
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Local credentials (used during local development & testing)
GITHUB_CLIENT_ID_LOCAL=your_github_client_id_here
GITHUB_CLIENT_SECRET_LOCAL=your_github_client_secret_here

# Optional: force a mode regardless of the auto-detection above.
# GITHUB_ENV=local

# ── Server ──────────────────────────────────────────────────────────────────
# Port the Express server listens on (locally). Render injects its own $PORT.
PORT=3000

# Secret used to sign session cookies. Use a long random string in production.
SESSION_SECRET=change_me_to_a_long_random_string

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Replaces the old data/projects.json store. On Render, use the Internal
# Database URL from your managed Postgres instance. Locally, e.g.:
#   postgres://postgres:postgres@localhost:5432/cia
DATABASE_URL=your_database_url
