{
  "name": "cloud-infrastructure-architect",
  "version": "2.0.0",
  "private": true,
  "description": "Autonomous Technical Sales Consultant — fullstack AWS architecture designer powered by Chutes LLM.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "node server.js",
    "client": "npm --prefix client run dev",
    "client:install": "npm --prefix client install",
    "client:build": "npm --prefix client run build",
    "build": "npm run client:install && npm run client:build",
    "postinstall": "npm --prefix client install --no-audit --no-fund"
  },
  "dependencies": {
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.19.0",
    "pg": "^8.21.0"
  },
  "engines": {
    "node": ">=18"
  }
}
